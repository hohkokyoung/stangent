{
  "_comment": "MCP server definitions. Only agentic_mcp is enabled by default. To activate others, add their name to enabledMcpjsonServers in .claude/settings.json. Fill in credentials for dbhub/supabase before enabling them.",
  "mcpServers": {
    "agentic_mcp": {
      "command": "python3",
      "args": [".claude/mcp/agentic_mcp.py"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "maestro": {
      "command": "maestro",
      "args": ["mcp"]
    },
    "dbhub": {
      "command": "npx",
      "args": [
        "-y",
        "@bytebase/dbhub",
        "--transport",
        "stdio",
        "--dsn",
        "REPLACE_WITH_DSN"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--access-token", "REPLACE_WITH_SUPABASE_PAT",
        "--project-ref",  "REPLACE_WITH_PROJECT_REF"
      ]
    }
  }
}
